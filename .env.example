# ============================================
# AegisIQ Environment Configuration
# Copy this file to .env and fill in the values
# ============================================

# --- Database ---
POSTGRES_DB=aegisiq
POSTGRES_USER=aegisiq
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_PORT=5432

# --- Backend ---
BACKEND_PORT=8000
DATABASE_URL=postgresql://aegisiq:change_me_in_production@postgres:5432/aegisiq
JWT_SECRET=change_me_to_a_secure_random_string
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=30
JWT_REFRESH_EXPIRATION_DAYS=7

# --- Frontend ---
FRONTEND_PORT=80
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_APP_NAME=PWNDORA SkillScan X

# --- AI Provider ---
LLM_PROVIDER=ollama
DEMO_MODE=false
GEMINI_API_KEY=
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large-latest
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3
LLM_TIMEOUT=120
LLM_MAX_RETRIES=3

# --- Nginx ---
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# --- Monitoring ---
LOG_LEVEL=INFO
ENABLE_AUDIT_LOGGING=true
